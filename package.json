{
  "name": "quantum-algorithm-explorer",
  "version": "0.1.0",
  "description": "Interactive quantum algorithm visualizer",
  "scripts": {
    "start": "concurrently \"uvicorn backend.main:app --port 8001\" \"node server.js\"",
    "dev": "concurrently \"uvicorn backend.main:app --port 8001 --reload\" \"npm run dev --prefix frontend\"",
    "build": "npm run build --prefix frontend",
    "install:all": "npm install && npm install --prefix frontend"
  },
  "dependencies": {
    "express": "^4.18.2",
    "http-proxy-middleware": "^3.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
